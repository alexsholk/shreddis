{
    "name": "alexsholk/shreddis",
    "description": "Redis serialization/compression benchmark",
    "require": {
        "php": "^8.4",
        "ext-igbinary": "*",
        "ext-lz4": "*",
        "ext-lzf": "*",
        "ext-msgpack": "*",
        "ext-redis": "*",
        "ext-zlib": "*",
        "ext-zstd": "*",
        "predis/predis": "^2.3",
        "symfony/console": "^8.0",
        "symfony/var-dumper": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "bin": [
        "bin/shreddis"
    ],
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
